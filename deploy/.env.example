# Copy to deploy/.env on the auth-service server

AUTH_JWT_SECRET=generate-with-openssl-rand-base64-48
AUTH_REFRESH_TOKEN_HMAC_KEY=generate-with-openssl-rand-base64-32
AUTH_JWT_ISSUER=auth-service

# Bootstrap: first-start only — creates tenant + user if absent (see deploy/README.md)
AUTH_SEED_TENANT_ID=my-app
AUTH_SEED_USER_EMAIL=admin@example.com
AUTH_SEED_USER_PASSWORD=change-me-strong-password
AUTH_SEED_USER_ROLE=ROLE_OPERATOR

# Optional when using GHCR pull deploy (pending CI/CD); clone-and-build ignores image name
AUTH_IMAGE_TAG=latest
# GITHUB_REPOSITORY_OWNER=your-github-user

AUTH_REDIS_ENABLED=false
